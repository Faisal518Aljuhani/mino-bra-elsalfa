# انسخ هذا الملف باسم .env وعبّي القيم الحقيقية

# منفذ السيرفر
PORT=3000

# مفتاح سري لتوقيع رموز الدخول JWT - غيّره لأي نص عشوائي طويل وقوي
JWT_SECRET=غير_هذا_النص_الى_نص_عشوائي_طويل_جدا_وسري_1234567890

# إعدادات إرسال البريد الإلكتروني (مثال: Gmail)
# لو تستخدم Gmail، لازم تفعل "التحقق بخطوتين" وتسوي "App Password" من إعدادات حسابك في جوجل
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# الرابط اللي بيروح فيه اللاعب عشان يفعّل حسابه (رابط الفرونت إند المحلي)
APP_BASE_URL=http://localhost:3000

# ===== حساب المشرف الأول (لوحة التحكم /admin.html) =====
# يُستخدم مرة وحدة فقط عند أول تشغيل للسيرفر (لو ما فيه أي مشرف بقاعدة البيانات بعد)
# عشان ينشئ أول حساب مشرف تلقائياً. غيّر القيم قبل النشر ولا تشارك هذا الملف مع أحد.
ADMIN_USERNAME=Faisal@&@&Aljuhani
ADMIN_PASSWORD=FaisalFaisal@12345

# ===== بوابة الدفع Moyasar (متجر لمّة كوين) =====
# خذها من لوحة تحكم Moyasar: https://dashboard.moyasar.com -> API Keys
# استخدم sk_test_... للتجربة، وsk_live_... بعد ما يفعّلون حسابك فعلياً
MOYASAR_SECRET_KEY=sk_test_ضع_مفتاحك_هنا

# سرّ الـ webhook: تحطه بلوحة Moyasar عند إنشاء الـ webhook (Settings -> Webhooks)
# ونفس القيمة بالضبط هنا، عشان نتأكد إن الإشعار جاي فعلاً من Moyasar
# رابط الـ webhook اللي تحطه بلوحتهم: https://موقعك/api/shop/webhook
MOYASAR_WEBHOOK_SECRET=غيّر_هذا_لنص_عشوائي_طويل_وسري
